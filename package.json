{
  "name": "@break-limits/mongoose-cache",
  "version": "0.0.0",
  "description": "A transparent, correctness-first data acceleration layer for Mongoose backed by Redis. Never serves stale data.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "keywords": [
    "mongoose",
    "redis",
    "cache",
    "caching",
    "invalidation",
    "mongodb"
  ],
  "author": "Break Limits",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "ioredis": ">=5",
    "mongoose": ">=7"
  },
  "dependencies": {
    "bson": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "ioredis": "^5.4.0",
    "ioredis-mock": "^8.13.1",
    "mongodb-memory-server": "^11.2.0",
    "mongoose": "^8.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
